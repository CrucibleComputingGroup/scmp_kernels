#!/bin/bash
#SBATCH --job-name=sens_grad
#SBATCH --partition=gpu-rtx6000
#SBATCH --account=nbleier_owned1
#SBATCH --reservation=rtx6000_arph_nodes
#SBATCH --gres=gpu:1
#SBATCH --cpus-per-gpu=8
#SBATCH --mem=64G
#SBATCH --time=01:00:00
#SBATCH --output=/scratch/nbleier_owned_root/nbleier_owned1/zhkangqi/scmp_llm/sensitivity_calib/slurm-%j.out
#SBATCH --error=/scratch/nbleier_owned_root/nbleier_owned1/zhkangqi/scmp_llm/sensitivity_calib/slurm-%j.err
#
# Gradient-based end-to-end sensitivity calibration (Method 3).
# Estimates ‖∂eps_pred/∂(matmul_out)‖² per (op, layer_bucket, t_bucket)
# via Hutchinson trace; emits a JSON sensitivity table for downstream
# threshold calibration to use as per-bucket weights.

set -euo pipefail

source /home/zhkangqi/miniconda3/etc/profile.d/conda.sh
conda activate qdit

REPO=/gpfs/accounts/nbleier_owned_root/nbleier_owned1/zhkangqi/scmp_llm
SCRATCH=/scratch/nbleier_owned_root/nbleier_owned1/zhkangqi/scmp_llm
OUT_DIR=${SCRATCH}/sensitivity_calib
mkdir -p "$OUT_DIR"

NUM_SAMPLES="${NUM_SAMPLES:-8}"
NUM_PROJ="${NUM_PROJ:-12}"
T_BUCKETS="${T_BUCKETS:-4}"
L_BUCKETS="${L_BUCKETS:-4}"
BATCH="${BATCH:-4}"
NUM_STEPS="${NUM_STEPS:-250}"

export PYTHONUNBUFFERED=1
export OMP_NUM_THREADS=${SLURM_CPUS_PER_GPU:-8}

cd "$REPO/Q-DiT"

echo "============================================================"
echo "sens_grad sbatch  job=${SLURM_JOB_ID}  start $(date)"
echo "  host=$(hostname)  gpu=$(nvidia-smi --query-gpu=name --format=csv,noheader | head -1)"
echo "  N_SAMPLES=$NUM_SAMPLES  K=$NUM_PROJ  T_BUCKETS=$T_BUCKETS  L_BUCKETS=$L_BUCKETS"
echo "  BATCH=$BATCH  NUM_STEPS=$NUM_STEPS"
echo "  OUT_DIR=$OUT_DIR"
echo "============================================================"

python -u scripts/calibrate_sensitivity_gradient.py \
    --wbits 8 --abits 8 --w_sym --a_sym \
    --sc_prec 8 --sc_fixed_level_prec \
    --mp_levels 256,128,64,0 \
    --image-size 256 \
    --num-sampling-steps "$NUM_STEPS" \
    --num_calib_samples "$NUM_SAMPLES" \
    --num_projections "$NUM_PROJ" \
    --timestep_buckets "$T_BUCKETS" \
    --layer_buckets "$L_BUCKETS" \
    --sens_calib_batch_size "$BATCH" \
    --sens_output_json "${OUT_DIR}/sensitivity_grad.json" \
    --sens_per_block_json "${OUT_DIR}/sensitivity_grad_per_block.json" \
    --seed 0
RC=$?

echo "[end]  $(date)  rc=$RC"
exit $RC
